// PAYROLL\
function renderPayroll()\{\
  var mc=document.getElementById('mainContent');\
  var now=new Date();\
  var selMonth=DB.payrollMonth||(now.getFullYear()+'-'+String(now.getMonth()+1).padStart(2,'0'));\
  var yr=parseInt(selMonth.split('-')[0]);\
  var mo=parseInt(selMonth.split('-')[1]);\
  var monthName=new Date(yr,mo-1,1).toLocaleString('en-ZA',\{month:'long',year:'numeric'\});\
  var grandTotal=0;\
  var rows=Object.keys(USERS).filter(function(k)\{return USERS[k].role==='coach';\}).map(function(ck)\{\
    var u=USERS[ck]; var rate=COACH_RATES[ck]||100;\
    var shifts=DB.shifts.filter(function(s)\{\
      if(s.coach!==ck) return false;\
      var d=s.date||''; if(!d) return false;\
      var parts=d.split('-'); return parseInt(parts[0])===yr&&parseInt(parts[1])===mo;\
    \});\
    var ps=(DB.personalSessions||[]).filter(function(s)\{\
      if(s.coach!==ck) return false;\
      var parts=(s.date||'').split('-'); return parseInt(parts[0])===yr&&parseInt(parts[1])===mo;\
    \});\
    var total=shifts.length+ps.length; var pay=total*rate; grandTotal+=pay;\
    return \{ck:ck,u:u,rate:rate,shifts:shifts,ps:ps,total:total,pay:pay\};\
  \});\
  var html='<div class="card"><div class="card-title">\uc0\u55357 \u56496  Monthly Payroll</div>'\
    +'<div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;flex-wrap:wrap">'\
    +'<div class="form-row" style="margin:0;flex:1;min-width:180px"><label class="form-label">Select Month</label>'\
    +'<input type="month" class="form-input" value="'+selMonth+'" onchange="setPayrollMonth(this.value)"></div>'\
    +'<div style="text-align:right"><div style="font-size:.78rem;color:var(--sub)">Total payout</div>'\
    +'<div style="font-size:1.8rem;font-weight:900;color:var(--green)">R'+grandTotal.toLocaleString()+'</div>'\
    +'<div style="font-size:.75rem;color:var(--sub)">'+monthName+'</div></div></div>';\
  rows.forEach(function(r)\{\
    html+='<div style="border:1.5px solid var(--border);border-radius:12px;padding:14px;margin-bottom:12px">'\
      +'<div style="display:flex;align-items:center;gap:10px;margin-bottom:12px">'\
      +'<div class="avatar" style="background:'+r.u.color+';width:40px;height:40px">'+r.u.avatar+'</div>'\
      +'<div style="flex:1"><div style="font-weight:800">'+r.u.name+'</div>'\
      +'<div style="font-size:.76rem;color:var(--sub)">Rate: <strong>R'+r.rate+'/class</strong></div></div>'\
      +'<div style="text-align:right"><div style="font-size:1.5rem;font-weight:900;color:var(--green)">R'+r.pay.toLocaleString()+'</div>'\
      +'<div style="font-size:.75rem;color:var(--sub)">'+r.total+' classes</div></div></div>'\
      +'<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;text-align:center">'\
      +'<div style="background:#f1f5f9;border-radius:8px;padding:8px"><div style="font-size:1.2rem;font-weight:900;color:#2563eb">'+r.shifts.length+'</div><div style="font-size:.7rem;color:var(--sub)">Group shifts</div></div>'\
      +'<div style="background:#f1f5f9;border-radius:8px;padding:8px"><div style="font-size:1.2rem;font-weight:900;color:#7c3aed">'+r.ps.length+'</div><div style="font-size:.7rem;color:var(--sub)">Personal</div></div>'\
      +'<div style="background:#dcfce7;border-radius:8px;padding:8px"><div style="font-size:1.2rem;font-weight:900;color:var(--green)">R'+r.pay.toLocaleString()+'</div><div style="font-size:.7rem;color:var(--sub)">Total pay</div></div></div>';\
    if(r.shifts.length||r.ps.length)\{\
      html+='<div style="margin-top:10px;font-size:.78rem;color:var(--sub)">';\
      r.shifts.forEach(function(s)\{\
        var pg=getPG(s.playgroup);\
        html+='<div style="padding:3px 0;border-top:1px solid var(--border);display:flex;justify-content:space-between">'\
          +'<span>'+(pg?pg.emoji+' '+pg.label:s.playgroup)+' \'b7 '+s.day+(s.date?' ('+s.date+')':'')+'</span>'\
          +'<span style="color:var(--green);font-weight:700">R'+r.rate+'</span></div>';\
      \});\
      r.ps.forEach(function(s)\{\
        html+='<div style="padding:3px 0;border-top:1px solid var(--border);display:flex;justify-content:space-between">'\
          +'<span>\uc0\u55358 \u56781  Personal \'b7 '+h(s.clientName)+' \'b7 '+s.date+'</span>'\
          +'<span style="color:var(--green);font-weight:700">R'+r.rate+'</span></div>';\
      \});\
      html+='</div>';\
    \}\
    html+='</div>';\
  \});\
  html+='<button class="btn btn-gold" style="width:100%" onclick="exportPayrollCSV()">\uc0\u55357 \u56549  Export Payroll CSV</button></div>';\
  mc.innerHTML=html;\
\}\
function setPayrollMonth(v)\{ DB.payrollMonth=v; save(); renderPayroll(); \}\
\
// EXPENSES\
function renderExpenses()\{\
  var mc=document.getElementById('mainContent');\
  var now=new Date();\
  var selMonth=DB.expenseMonth||(now.getFullYear()+'-'+String(now.getMonth()+1).padStart(2,'0'));\
  var yr=parseInt(selMonth.split('-')[0]);\
  var mo=parseInt(selMonth.split('-')[1]);\
  var monthName=new Date(yr,mo-1,1).toLocaleString('en-ZA',\{month:'long',year:'numeric'\});\
  var exp=(DB.expenses&&DB.expenses[selMonth])||\{\};\
  var rent=exp.rent!=null?exp.rent:4500;\
  var video=exp.video!=null?exp.video:2000;\
  var jozi=exp.jozi!=null?exp.jozi:205;\
  var amanda=exp.amanda!=null?exp.amanda:0;\
  var mike=exp.mike!=null?exp.mike:0;\
  var extras=exp.extras||[];\
  var extrasTotal=extras.reduce(function(a,e)\{return a+Number(e.amount||0);\},0);\
  var fixedTotal=rent+video+jozi+Number(amanda)+Number(mike)+extrasTotal;\
  var payrollTotal=0;\
  Object.keys(USERS).filter(function(k)\{return USERS[k].role==='coach';\}).forEach(function(ck)\{\
    var rate=COACH_RATES[ck]||100;\
    var sh=DB.shifts.filter(function(s)\{\
      if(s.coach!==ck) return false;\
      var d=s.date||''; if(!d) return false;\
      var parts=d.split('-'); return parseInt(parts[0])===yr&&parseInt(parts[1])===mo;\
    \}).length;\
    var ps=(DB.personalSessions||[]).filter(function(s)\{\
      if(s.coach!==ck) return false;\
      var parts=(s.date||'').split('-'); return parseInt(parts[0])===yr&&parseInt(parts[1])===mo;\
    \}).length;\
    payrollTotal+=(sh+ps)*rate;\
  \});\
  var grand=fixedTotal+payrollTotal;\
  var html='<div class="card"><div class="card-title">\uc0\u55356 \u57318  Monthly Business Expenses</div>'\
    +'<div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;flex-wrap:wrap">'\
    +'<div class="form-row" style="margin:0;flex:1;min-width:180px"><label class="form-label">Select Month</label>'\
    +'<input type="month" class="form-input" value="'+selMonth+'" onchange="setExpenseMonth(this.value)"></div>'\
    +'<div style="text-align:right"><div style="font-size:.78rem;color:var(--sub)">Total outgoings</div>'\
    +'<div style="font-size:1.8rem;font-weight:900;color:var(--red)">R'+grand.toLocaleString()+'</div>'\
    +'<div style="font-size:.75rem;color:var(--sub)">'+monthName+'</div></div></div>'\
    +'<div style="font-size:.82rem;font-weight:700;color:var(--sub);margin-bottom:8px;text-transform:uppercase;letter-spacing:.5px">Fixed Costs</div>'\
    +expRow('Rent','rent',rent,selMonth,'Adjustable for inflation/raises')\
    +expRow('Videography / Photography (Jared)','video',video,selMonth,'Adjustable for inflation/raises')\
    +expRow('Jozi Kids Marketing','jozi',jozi,selMonth,'Adjustable for inflation/raises')\
    +'<div style="font-size:.82rem;font-weight:700;color:var(--sub);margin:16px 0 8px;text-transform:uppercase;letter-spacing:.5px">Variable Costs</div>'\
    +expRow('Amanda - Admin','amanda',amanda,selMonth,'Enter monthly amount')\
    +expRow('Mike - Admin/Variable','mike',mike,selMonth,'Enter monthly amount')\
    +'<div style="font-size:.82rem;font-weight:700;color:var(--sub);margin:16px 0 8px;text-transform:uppercase;letter-spacing:.5px">Extra / Once-off Expenses</div>'\
    +'<div id="extraExpList">'+renderExtraExps(extras,selMonth)+'</div>'\
    +'<button class="btn btn-success btn-sm" style="margin-top:8px;width:100%" onclick="addExtraExp(\\''+selMonth+'\\')">+ Add Extra Expense</button>'\
    +'<div style="border-top:2px solid var(--border);margin:16px 0;padding-top:14px">'\
    +'<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px"><span style="font-weight:700">Fixed + Variable</span><span style="font-weight:900;font-size:1.1rem;color:var(--red)">R'+fixedTotal.toLocaleString()+'</span></div>'\
    +'<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px"><span style="font-weight:700">Coach Payroll</span><span style="font-weight:900;font-size:1.1rem;color:var(--red)">R'+payrollTotal.toLocaleString()+'</span></div>'\
    +'<div style="display:flex;justify-content:space-between;align-items:center;background:#fee2e2;border-radius:10px;padding:12px 14px">'\
    +'<span style="font-weight:900;font-size:1rem">Total Monthly Outgoings</span>'\
    +'<span style="font-weight:900;font-size:1.5rem;color:var(--red)">R'+grand.toLocaleString()+'</span></div></div>'\
    +'<button class="btn btn-gold" style="width:100%;margin-top:4px" onclick="exportExpensesCSV(\\''+selMonth+'\\')">\uc0\u55357 \u56549  Export Expenses CSV</button></div>';\
  mc.innerHTML=html;\
\}\
function expRow(label,key,val,month,hint)\{\
  return '<div style="display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid var(--border);flex-wrap:wrap">'\
    +'<div style="flex:1;min-width:140px"><div style="font-weight:600;font-size:.9rem">'+label+'</div><div style="font-size:.75rem;color:var(--sub)">'+hint+'</div></div>'\
    +'<div style="display:flex;align-items:center;gap:6px"><span style="font-weight:700;color:var(--sub)">R</span>'\
    +'<input type="number" value="'+val+'" min="0" style="width:110px;padding:8px 10px;border:1.5px solid var(--border);border-radius:8px;font-size:.95rem;font-weight:700;text-align:right" onchange="saveExpense(\\''+key+'\\',this.value,\\''+month+'\\')">'\
    +'</div></div>';\
\}\
function renderExtraExps(extras,month)\{\
  if(!extras.length) return '<div style="color:var(--sub);font-size:.83rem;padding:8px 0">No extra expenses added yet.</div>';\
  return extras.map(function(e,i)\{\
    return '<div style="display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid var(--border);flex-wrap:wrap">'\
      +'<div style="flex:1;min-width:120px"><div style="font-weight:600;font-size:.9rem">'+h(e.label||'Unnamed expense')+'</div></div>'\
      +'<div style="display:flex;align-items:center;gap:6px"><span style="font-weight:700;color:var(--sub)">R</span>'\
      +'<input type="number" value="'+(e.amount||0)+'" min="0" style="width:100px;padding:7px 10px;border:1.5px solid var(--border);border-radius:8px;font-size:.92rem;font-weight:700;text-align:right" onchange="updateExtraAmt('+i+',this.value,\\''+month+'\\')">'\
      +'<button class="btn btn-danger btn-sm" onclick="deleteExtraExp('+i+',\\''+month+'\\')">\uc0\u55357 \u56785 </button></div></div>';\
  \}).join('');\
\}\
function addExtraExp(month)\{\
  var label=prompt('Enter expense name (e.g. Equipment, Printing):');\
  if(!label||!label.trim()) return;\
  if(!DB.expenses) DB.expenses=\{\};\
  if(!DB.expenses[month]) DB.expenses[month]=\{\};\
  if(!DB.expenses[month].extras) DB.expenses[month].extras=[];\
  DB.expenses[month].extras.push(\{label:label.trim(),amount:0\});\
  save(); renderExpenses();\
\}\
function updateExtraAmt(idx,val,month)\{\
  if(!DB.expenses||!DB.expenses[month]||!DB.expenses[month].extras) return;\
  DB.expenses[month].extras[idx].amount=Number(val); save(); renderExpenses();\
\}\
function deleteExtraExp(idx,month)\{\
  if(!confirm('Remove this expense?')) return;\
  DB.expenses[month].extras.splice(idx,1); save(); renderExpenses();\
\}\
function saveExpense(key,val,month)\{\
  if(!DB.expenses) DB.expenses=\{\};\
  if(!DB.expenses[month]) DB.expenses[month]=\{\};\
  DB.expenses[month][key]=Number(val); save(); renderExpenses();\
\}\
function setExpenseMonth(v)\{ DB.expenseMonth=v; save(); renderExpenses(); \}\
function exportExpensesCSV(month)\{\
  var exp=(DB.expenses&&DB.expenses[month])||\{\};\
  var rows=['Category,Amount (R)',\
    'Rent,'+(exp.rent!=null?exp.rent:4500),\
    'Videography/Photography,'+(exp.video!=null?exp.video:2000),\
    'Jozi Kids Marketing,'+(exp.jozi!=null?exp.jozi:205),\
    'Amanda Admin,'+(exp.amanda||0),\
    'Mike Variable,'+(exp.mike||0)\
  ];\
  (exp.extras||[]).forEach(function(e)\{ rows.push('"'+e.label+'",'+( e.amount||0)); \});\
  dlCSV(rows.join('\\n'),'CFC_Expenses_'+month+'.csv');\
\}\
\
// COACH VIEWS\
function renderMySchedule()\{\
  var mc=document.getElementById('mainContent');\
  var myShifts=DB.shifts.filter(function(s)\{return s.coach===currentUser.key;\});\
  var day=todayDay();\
  var ord=['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'];\
  var html='<div class="today-header"><div class="today-date">Hi '+currentUser.name+'! '+currentUser.avatar+'</div><div class="today-sub">'+todayFull()+'</div></div>'\
    +'<div class="card"><div class="card-title">\uc0\u55357 \u56517  Your Shifts</div>';\
  if(myShifts.length)\{\
    ord.forEach(function(d)\{\
      var shifts=myShifts.filter(function(s)\{return s.day===d;\}); if(!shifts.length) return;\
      var isToday=d===day;\
      html+='<div class="week-day has-shift'+(isToday?' today-day':'')+'"><div class="week-day-name">'+(isToday?'\uc0\u55357 \u57313  ':'')+d+(isToday?' (Today)':'')+'</div>';\
      shifts.forEach(function(s)\{\
        var pg=getPG(s.playgroup);\
        html+='<div class="week-day-info">'+(pg?pg.emoji+' <strong>'+pg.label+'</strong>':'')+' \'b7 '+s.startTime+'-'+s.endTime+(s.date?' \'b7 '+s.date:'')+'</div>';\
      \});\
      html+='</div>';\
    \});\
  \} else \{\
    html+='<div style="color:var(--sub);padding:14px 0">Amanda has not allocated any shifts yet.</div>';\
  \}\
  html+='</div>';\
  mc.innerHTML=html;\
\}\
function renderMarkAttendance()\{\
  var mc=document.getElementById('mainContent');\
  var day=todayDay(); var date=todayDate();\
  var myShifts=DB.shifts.filter(function(s)\{return s.coach===currentUser.key&&s.day===day;\});\
  if(!myShifts.length)\{\
    mc.innerHTML='<div class="card" style="text-align:center;padding:32px"><div style="font-size:3rem">\uc0\u55357 \u56523 </div><div style="font-weight:700;margin-top:12px">No shift today</div><div style="color:var(--sub);margin-top:6px">Contact Amanda if this is an error.</div></div>';\
    return;\
  \}\
  var html='<div class="today-header"><div class="today-date">'+day+' Session</div><div class="today-sub">'+todayFull()+'</div></div>';\
  myShifts.forEach(function(shift)\{\
    var pg=getPG(shift.playgroup);\
    var students=DB.students.filter(function(s)\{return s.active&&s.playgroup===shift.playgroup&&s.day===day;\});\
    html+='<div style="background:'+(pg?pg.color:'#2563eb')+';color:#fff;border-radius:10px;padding:10px 14px;margin-bottom:8px;font-weight:700">'+(pg?pg.emoji+' '+pg.label:'')+' \'b7 '+shift.startTime+'-'+shift.endTime+'</div>'\
      +'<div class="card" style="margin-bottom:16px">'\
      +'<input class="search-bar" placeholder="Search..." oninput="filterCoachAtt(this.value,\\''+shift.playgroup+'\\',\\''+day+'\\',\\''+date+'\\',\\'al_'+shift.id+'\\')">'\
      +'<div id="al_'+shift.id+'">'+renderCoachAttRows(students,date)+'</div></div>';\
  \});\
  mc.innerHTML=html;\
\}\
function filterCoachAtt(q,pgId,day,date,listId)\{\
  var s=DB.students.filter(function(s)\{return s.active&&s.playgroup===pgId&&s.day===day&&fullName(s).toLowerCase().indexOf(q.toLowerCase())>=0;\});\
  var el=document.getElementById(listId); if(el) el.innerHTML=renderCoachAttRows(s,date);\
\}\
function renderCoachAttRows(students,date)\{\
  if(!students.length) return '<div style="color:var(--sub);padding:12px 0">No students for this session.</div>';\
  return students.map(function(s)\{\
    var a=DB.attendance[attKey(date,s.id)]||\{\};\
    return '<div class="student-row" id="row_'+s.id+'">'\
      +'<div style="flex:1"><div class="student-name">'+h(fullName(s))+'</div>'\
      +'<div style="display:flex;gap:5px;margin-top:2px"><span class="badge blue">'+h(s.classifier)+'</span>'\
      +'<span style="font-size:.7rem;color:var(--sub);margin-top:3px" id="ts_'+s.id+'">'+(a.timestamp?'\uc0\u10003  '+a.timestamp:'Not marked')+'</span></div>'\
      +'<input class="notes-input" placeholder="Notes..." value="'+h(a.notes||'')+'" onchange="updateNotes(\\''+s.id+'\\',\\''+date+'\\',this.value)"></div>'\
      +'<div class="att-btns">'\
      +'<button class="att-btn present'+(a.status==='present'?' active':'')+'" onclick="markAtt(\\''+s.id+'\\',\\''+date+'\\',\\'present\\')" id="bp_'+s.id+'">\uc0\u10003 </button>'\
      +'<button class="att-btn absent'+(a.status==='absent'?' active':'')+'" onclick="markAtt(\\''+s.id+'\\',\\''+date+'\\',\\'absent\\')" id="ba_'+s.id+'">\uc0\u10007 </button>'\
      +'</div></div>';\
  \}).join('');\
\}\
function renderMyStats()\{\
  var mc=document.getElementById('mainContent');\
  var myShifts=DB.shifts.filter(function(s)\{return s.coach===currentUser.key;\});\
  var hrs=myShifts.reduce(function(acc,s)\{\
    var sh=parseInt(s.startTime.split(':')[0])*60+parseInt(s.startTime.split(':')[1]);\
    var eh=parseInt(s.endTime.split(':')[0])*60+parseInt(s.endTime.split(':')[1]);\
    return acc+(eh-sh)/60;\
  \},0);\
  var stu=myShifts.reduce(function(acc,s)\{return acc+DB.students.filter(function(st)\{return st.active&&st.playgroup===s.playgroup&&st.day===s.day;\}).length;\},0);\
  var ps=(DB.personalSessions||[]).filter(function(s)\{return s.coach===currentUser.key;\}).length;\
  var html='<div class="card"><div class="card-title">\uc0\u55357 \u56520  My Stats</div>'\
    +'<div class="stat-grid">'\
    +'<div class="stat-box blue"><div class="stat-num">'+myShifts.length+'</div><div class="stat-label">Shifts</div></div>'\
    +'<div class="stat-box green"><div class="stat-num">'+hrs.toFixed(1)+'</div><div class="stat-label">Hours</div></div>'\
    +'<div class="stat-box gold"><div class="stat-num">'+stu+'</div><div class="stat-label">Students</div></div>'\
    +'<div class="stat-box"><div class="stat-num" style="color:#7c3aed">'+ps+'</div><div class="stat-label">Personal Classes</div></div></div></div>'\
    +'<div class="card"><div class="card-title">\uc0\u55357 \u56523  Shift History</div>';\
  if(myShifts.length)\{\
    html+='<div class="table-wrap"><table><tr><th>Playgroup</th><th>Day</th><th>Date</th><th>Time</th></tr>';\
    myShifts.forEach(function(s)\{\
      var pg=getPG(s.playgroup);\
      html+='<tr><td>'+(pg?pg.emoji+' '+pg.label:s.playgroup)+'</td><td>'+s.day+'</td><td>'+(s.date||'-')+'</td><td>'+s.startTime+'-'+s.endTime+'</td></tr>';\
    \});\
    html+='</table></div>';\
  \} else \{ html+='<div style="color:var(--sub)">No shifts yet.</div>'; \}\
  html+='</div>';\
  mc.innerHTML=html;\
\}\
\
initLogin();\
</script>\
