  document.getElementById('pinLabel').textContent='PIN for '+USERS[k].name;\
  document.getElementById('loginErr').textContent='';\
\}\
function goBack()\{\
  document.getElementById('userSelect').classList.remove('hidden');\
  document.getElementById('pinSection').classList.add('hidden');\
  pinBuffer=''; updatePinDots();\
\}\
function pinPress(d)\{ if(pinBuffer.length>=4)return; pinBuffer+=d; updatePinDots(); if(pinBuffer.length===4)setTimeout(tryLogin,150); \}\
function pinBack()\{ pinBuffer=pinBuffer.slice(0,-1); updatePinDots(); \}\
function pinClear()\{ pinBuffer=''; updatePinDots(); \}\
function updatePinDots()\{ for(var i=0;i<4;i++) document.getElementById('d'+i).classList.toggle('filled',i<pinBuffer.length); \}\
function tryLogin()\{\
  var u=USERS[selectedUserKey];\
  var activePin=(DB.coachPins||\{\})[selectedUserKey]||u.pin;\
  if(pinBuffer===activePin)\{\
    currentUser=Object.assign(\{key:selectedUserKey\},u);\
    document.getElementById('loginScreen').classList.add('hidden');\
    document.getElementById('app').classList.remove('hidden');\
    document.getElementById('topbarUser').textContent=u.avatar+' '+u.name+' \'b7 '+(u.role==='admin'?'Super Admin':'Coach');\
    initApp();\
  \} else \{\
    document.getElementById('loginErr').textContent='Incorrect PIN. Try again.';\
    pinBuffer=''; updatePinDots();\
  \}\
\}\
function logout()\{\
  currentUser=null; pinBuffer=''; selectedUserKey=null; currentPG='aisj'; currentTab='';\
  document.getElementById('app').classList.add('hidden');\
  document.getElementById('loginScreen').classList.remove('hidden');\
  document.getElementById('userSelect').classList.remove('hidden');\
  document.getElementById('pinSection').classList.add('hidden');\
  document.getElementById('pgBar').classList.add('hidden');\
