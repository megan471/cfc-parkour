// REPORTS\
function renderReports()\{\
  var mc=document.getElementById('mainContent');\
  var pg=getPG(currentPG);\
  var rows=DB.students.filter(function(s)\{return s.active&&s.playgroup===currentPG&&s.day!=='flexible';\}).map(function(s)\{\
    var records=Object.keys(DB.attendance).filter(function(k)\{return k.indexOf('_'+s.id)>0;\}).map(function(k)\{return DB.attendance[k];\});\
    var present=records.filter(function(v)\{return v.status==='present';\}).length;\
    var total=records.length;\
    return \{s:s,total:total,present:present,absent:total-present,pct:total?Math.round(present/total*100):0\};\
  \});\
  window._reportRows=rows;\
  mc.innerHTML='<div class="pg-section-header" style="background:'+pg.color+'">'+pg.emoji+' '+pg.label+' - Reports</div>'\
    +'<div class="card"><input class="search-bar" placeholder="Search..." oninput="filterReport(this.value)">'\
    +'<div id="reportTable">'+buildReportTable(rows)+'</div></div>'\
    +'<div class="card"><div class="card-title">\uc0\u55357 \u56549  Export</div>'\
    +'<div style="display:flex;flex-wrap:wrap;gap:10px">'\
    +'<button class="btn btn-primary" onclick="exportCSV()">\uc0\u55357 \u56522  Attendance CSV</button>'\
    +'<button class="btn btn-gold" onclick="exportPayrollCSV()">\uc0\u55357 \u56496  Payroll CSV</button></div></div>';\
\}\
function buildReportTable(rows)\{\
  if(!rows.length) return '<div style="color:var(--sub)">No data yet.</div>';\
  var html='<div class="table-wrap"><table><tr><th>Student</th><th>Day</th><th>Group</th><th>Sessions</th><th>Present</th><th>Absent</th><th>%</th></tr>';\
  rows.forEach(function(r)\{\
    var cls=r.pct>=80?'green':r.pct>=60?'gold':'red';\
    html+='<tr><td><strong>'+h(fullName(r.s))+'</strong></td><td>'+r.s.day+'</td><td>'+h(r.s.classifier)+'</td>'\
      +'<td>'+r.total+'</td><td style="color:var(--green);font-weight:700">'+r.present+'</td>'\
      +'<td style="color:var(--red);font-weight:700">'+r.absent+'</td>'\
      +'<td><span class="badge '+cls+'">'+r.pct+'%</span></td></tr>';\
  \});\
  html+='</table></div>';\
  return html;\
\}\
function filterReport(q)\{\
  document.getElementById('reportTable').innerHTML=buildReportTable((window._reportRows||[]).filter(function(r)\{return fullName(r.s).toLowerCase().indexOf(q.toLowerCase())>=0;\}));\
\}\
function exportCSV()\{\
  var rows=['Student,Playgroup,Day,Classifier,Sessions,Present,Absent,Attendance%'];\
  DB.students.filter(function(s)\{return s.active&&s.playgroup===currentPG;\}).forEach(function(s)\{\
    var records=Object.keys(DB.attendance).filter(function(k)\{return k.indexOf('_'+s.id)>0;\}).map(function(k)\{return DB.attendance[k];\});\
    var present=records.filter(function(v)\{return v.status==='present';\}).length;\
    var total=records.length;\
    var pg=getPG(s.playgroup);\
    rows.push('"'+fullName(s)+'",'+(pg?pg.label:'')+','+s.day+','+s.classifier+','+total+','+present+','+(total-present)+','+(total?Math.round(present/total*100):0)+'%');\
  \});\
  dlCSV(rows.join('\\n'),'CFC_'+(getPG(currentPG)?getPG(currentPG).label:currentPG)+'_Attendance.csv');\
\}\
function exportPayrollCSV()\{\
  var rows=['Coach,Playgroup,Day,Date,Start,End'];\
  DB.shifts.forEach(function(s)\{\
    var pg=getPG(s.playgroup);\
    rows.push(coachName(s.coach)+','+(pg?pg.label:s.playgroup)+','+s.day+','+(s.date||'')+','+s.startTime+','+s.endTime);\
  \});\
  dlCSV(rows.join('\\n'),'CFC_Payroll.csv');\
\}\
function dlCSV(content,filename)\{\
  var a=document.createElement('a');\
  a.href='data:text/csv;charset=utf-8,'+encodeURIComponent(content);\
  a.download=filename; a.click();\
\}\
