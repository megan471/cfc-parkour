function buildPGBar()\{\
  var bar=document.getElementById('pgBar'); bar.innerHTML='';\
  PLAYGROUPS.forEach(function(pg)\{\
    var c=document.createElement('div');\
    c.className='pg-chip'+(pg.id===currentPG?' active':'');\
    c.textContent=pg.emoji+' '+pg.label;\
    c.style.color=pg.id===currentPG?pg.color:'rgba(255,255,255,.5)';\
    c.style.borderColor=pg.id===currentPG?pg.color:'transparent';\
    c.onclick=(function(id)\{ return function()\{ currentPG=id; buildPGBar(); renderTab(currentTab); \}; \})(pg.id);\
    bar.appendChild(c);\
  \});\
\}\
function buildNavTabs()\{\
  var tabs=currentUser.role==='admin'\
    ?[\{id:'overview',label:'\uc0\u55357 \u56522  Overview'\},\{id:'attendance',label:'\u9989  Attendance'\},\{id:'schedule',label:'\u55357 \u56517  Schedule'\},\{id:'students',label:'\u55357 \u56421  Students'\},\{id:'corrections',label:'\u9999 \u65039  Corrections'\},\{id:'reports',label:'\u55357 \u56523  Reports'\},\{id:'payroll',label:'\u55357 \u56496  Payroll'\},\{id:'expenses',label:'\u55356 \u57318  Expenses'\},\{id:'pinmanage',label:'\u55357 \u56592  PINs'\}]\
    :[\{id:'mySchedule',label:'\uc0\u55357 \u56517  My Schedule'\},\{id:'markAttendance',label:'\u9989  Mark Attendance'\},\{id:'myStats',label:'\u55357 \u56520  My Stats'\}];\
  var nt=document.getElementById('navTabs'); nt.innerHTML='';\
  if(!currentTab||!tabs.filter(function(t)\{return t.id===currentTab;\}).length) currentTab=tabs[0].id;\
  tabs.forEach(function(t)\{\
    var el=document.createElement('div');\
    el.className='nav-tab'+(t.id===currentTab?' active':'');\
    el.textContent=t.label;\
    el.onclick=(function(id,elem)\{\
      return function()\{\
        currentTab=id;\
        document.querySelectorAll('.nav-tab').forEach(function(x)\{x.classList.remove('active');\});\
        elem.classList.add('active');\
        renderTab(id);\
      \};\
    \})(t.id,el);\
    nt.appendChild(el);\
  \});\
\}\
function renderTab(id)\{\
  document.getElementById('mainContent').innerHTML='';\
  if(id==='overview') renderOverview();\
  else if(id==='attendance')\{ if(currentPG==='personal') renderPersonalAttendance(); else renderAdminAttendance(); \}\
  else if(id==='schedule') renderScheduleAdmin();\
  else if(id==='students')\{ if(currentPG==='personal') renderPersonalClients(); else renderStudents(); \}\
  else if(id==='corrections') renderCorrections();\
  else if(id==='reports') renderReports();\
  else if(id==='payroll') renderPayroll();\
  else if(id==='expenses') renderExpenses();\
  else if(id==='pinmanage') renderPINManage();\
  else if(id==='mySchedule') renderMySchedule();\
  else if(id==='markAttendance') renderMarkAttendance();\
  else if(id==='myStats') renderMyStats();\
\}\
