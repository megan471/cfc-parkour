function todayFull()\{ return new Date().toLocaleDateString('en-ZA',\{weekday:'long',year:'numeric',month:'long',day:'numeric'\}); \}\
function tsNow()\{ return new Date().toLocaleTimeString('en-ZA',\{hour:'2-digit',minute:'2-digit'\}); \}\
function attKey(d,s)\{ return d+'_'+s; \}\
function uid()\{ return 'id_'+Date.now()+'_'+Math.random().toString(36).slice(2,7); \}\
