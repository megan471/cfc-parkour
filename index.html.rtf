function renderStudents()\{\
  var mc=document.getElementById('mainContent');\
  var pg=getPG(currentPG);\
  var pgStudents=DB.students.filter(function(s)\{return s.playgroup===currentPG;\});\
  var pgDays=getDaysForPG(currentPG);\
  var classOpts=classifierOptions(currentPG).map(function(c)\{return '<option>'+c+'</option>';\}).join('');\
  var dayOpts=pgDays.map(function(d)\{return '<option>'+d+'</option>';\}).join('');\
  mc.innerHTML='<div class="pg-section-header" style="background:'+pg.color+'">'+pg.emoji+' '+pg.label+' - Student Register</div>'\
    +'<div class="card"><div class="card-title">+ Add Student</div>'\
    +'<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">'\
    +'<div class="form-row"><label class="form-label">First Name</label><input class="form-input" id="stFirst" placeholder="First name"></div>'\
    +'<div class="form-row"><label class="form-label">Last Name</label><input class="form-input" id="stLast" placeholder="Last name (optional)"></div></div>'\
    +'<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">'\
    +'<div class="form-row"><label class="form-label">'+pg.classifierLabel+'</label><select class="form-select" id="stClass">'+classOpts+'</select></div>'\
    +'<div class="form-row"><label class="form-label">Day</label><select class="form-select" id="stDay">'+dayOpts+'</select></div></div>'\
    +'<button class="btn btn-primary" onclick="addStudent()">+ Add Student</button></div>'\
    +'<div class="card"><div class="card-title">\uc0\u55357 \u56421  '+pg.label+' ('+pgStudents.filter(function(s)\{return s.active;\}).length+' active)</div>'\
    +'<input class="search-bar" placeholder="Search..." oninput="filterStudents(this.value)">'\
    +'<div id="studentTable">'+renderStudentTable(pgStudents,pgDays)+'</div></div>';\
\}\
function filterStudents(q)\{\
  var f=DB.students.filter(function(s)\{return s.playgroup===currentPG&&fullName(s).toLowerCase().indexOf(q.toLowerCase())>=0;\});\
  document.getElementById('studentTable').innerHTML=renderStudentTable(f,getDaysForPG(currentPG));\
\}\
function renderStudentTable(students,pgDays)\{\
  if(!students.length) return '<div style="color:var(--sub);padding:14px 0">No students yet.</div>';\
  var days=pgDays||getDaysForPG(currentPG);\
  var seen=\{\}; var unique=students.filter(function(s)\{if(seen[s.id])return false;seen[s.id]=true;return true;\});\
  return days.map(function(day)\{\
    var ds=unique.filter(function(s)\{return s.day===day;\});\
    if(!ds.length) return '';\
    var html='<div style="margin-bottom:16px"><div style="font-weight:800;color:#2563eb;font-size:.87rem;margin-bottom:7px;padding:5px 0;border-bottom:2px solid #dbeafe">'+day+' - '+ds.filter(function(s)\{return s.active;\}).length+' students</div>';\
    ds.forEach(function(s)\{\
      html+='<div class="student-row" style="'+(s.active?'':'opacity:.4')+'">'\
        +'<div style="flex:1"><div class="student-name">'+h(fullName(s))+(s.active?'':' <span style="font-size:.7rem;color:var(--red)">(Inactive)</span>')+'</div>'\
        +'<div style="display:flex;gap:5px;margin-top:3px"><span class="badge blue">'+h(s.classifier)+'</span></div></div>'\
        +'<div style="display:flex;gap:6px">'\
        +'<button class="btn btn-sm '+(s.active?'btn-danger':'btn-success')+'" onclick="toggleStudent(\\''+s.id+'\\')">'+(s.active?'Deactivate':'Activate')+'</button>'\
        +'<button class="btn btn-danger btn-sm" onclick="deleteStudent(\\''+s.id+'\\')">\uc0\u55357 \u56785 </button></div></div>';\
    \});\
    html+='</div>';\
    return html;\
  \}).join('');\
\}\
function addStudent()\{\
  var first=document.getElementById('stFirst').value.trim();\
  var last=document.getElementById('stLast').value.trim();\
  var classifier=document.getElementById('stClass').value;\
  var day=document.getElementById('stDay').value;\
  if(!first)\{alert('Please enter a first name.');return;\}\
  DB.students.push(\{id:uid(),first:first,last:last,playgroup:currentPG,classifier:classifier,day:day,active:true\});\
  save(); renderStudents();\
\}\
function toggleStudent(id)\{\
  var s=DB.students.filter(function(x)\{return x.id===id;\})[0];\
  if(s)\{s.active=!s.active; save(); if(currentPG==='personal') renderPersonalClients(); else renderStudents();\}\
\}\
function deleteStudent(id)\{\
  if(!confirm('Permanently delete?')) return;\
  DB.students=DB.students.filter(function(s)\{return s.id!==id;\}); save();\
  if(currentPG==='personal') renderPersonalClients(); else renderStudents();\
\}\
