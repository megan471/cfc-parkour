// APP\
function initApp()\{\
  if(currentUser.role==='admin')\{ buildPGBar(); document.getElementById('pgBar').classList.remove('hidden'); \}\
  else document.getElementById('pgBar').classList.add('hidden');\
  currentTab=''; buildNavTabs(); renderTab(currentTab);\
