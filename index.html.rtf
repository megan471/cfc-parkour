function renderAttRows(students,date)\{\
  if(!students.length) return '<div style="color:var(--sub);padding:14px 0">No students scheduled today.</div>';\
  return students.map(function(s)\{\
    var a=DB.attendance[attKey(date,s.id)]||\{\};\
