function logPersonalSession()\{\
  var clientId=document.getElementById('psClient').value;\
  var coach=document.getElementById('psCoach').value;\
  var date=document.getElementById('psDate').value;\
  var status=document.getElementById('psStatus').value;\
  var start=document.getElementById('psStart').value;\
  var end=document.getElementById('psEnd').value;\
  var notes=document.getElementById('psNotes').value.trim();\
  if(!clientId)\{alert('Select a client.');return;\}\
  if(!coach)\{alert('Select a coach.');return;\}\
  if(!start||!end)\{alert('Enter start and end time.');return;\}\
  var client=DB.students.filter(function(s)\{return s.id===clientId;\})[0];\
  if(!DB.personalSessions) DB.personalSessions=[];\
  DB.personalSessions.push(\{id:uid(),clientId:clientId,clientName:fullName(client),clientAge:client.classifier,coach:coach,date:date,start:start,end:end,status:status,notes:notes,loggedAt:tsNow()\});\
  save(); renderPersonalAttendance();\
\}\
function renderPSHistory(sessions)\{\
  if(!sessions||!sessions.length) return '<div style="color:var(--sub);padding:14px 0">No sessions logged yet.</div>';\
  var sorted=sessions.slice().sort(function(a,b)\{return b.date.localeCompare(a.date);\});\
  var html='<div class="table-wrap"><table><tr><th>Date</th><th>Client</th><th>Coach</th><th>Time</th><th>Status</th><th>Notes</th><th></th></tr>';\
  sorted.forEach(function(s)\{\
    html+='<tr><td>'+s.date+'</td><td><strong>'+h(s.clientName)+'</strong></td><td>'+coachName(s.coach)+'</td>'\
      +'<td>'+s.start+'-'+s.end+'</td>'\
      +'<td><span class="badge '+(s.status==='present'?'green':'red')+'">'+(s.status==='present'?'Attended':'No Show')+'</span></td>'\
      +'<td style="font-size:.78rem;color:var(--sub)">'+h(s.notes||'-')+'</td>'\
      +'<td><button class="btn btn-danger btn-sm" onclick="deletePSSession(\\''+s.id+'\\')">\uc0\u55357 \u56785 </button></td></tr>';\
  \});\
  html+='</table></div>';\
  return html;\
\}\
function filterPSSessions(q)\{\
  document.getElementById('psHistory').innerHTML=renderPSHistory((window._allPSSessions||[]).filter(function(s)\{\
    return s.clientName.toLowerCase().indexOf(q.toLowerCase())>=0||coachName(s.coach).toLowerCase().indexOf(q.toLowerCase())>=0;\
  \}));\
\}\
function deletePSSession(id)\{\
  if(!confirm('Delete this session?')) return;\
  DB.personalSessions=DB.personalSessions.filter(function(s)\{return s.id!==id;\}); save(); renderPersonalAttendance();\
\}\
