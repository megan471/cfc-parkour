    +'<input type="date" class="form-input" id="shDate" value="'+todayDate()+'"></div>'\
    +'<button class="btn btn-primary" style="width:100%" onclick="addShift()">+ Allocate Shift</button></div>'\
    +'<div class="card"><div class="card-title">\uc0\u55357 \u56523  All Shifts</div>'\
    +'<div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px">'\
    +'<button class="btn btn-sm" style="background:#f1f5f9" onclick="filterShifts(\\'all\\')">All</button>'\
    +PLAYGROUPS.map(function(p)\{return '<button class="btn btn-sm" style="background:'+p.color+'22;color:'+p.color+'" onclick="filterShifts(\\''+p.id+'\\')">'+p.emoji+' '+p.label+'</button>';\}).join('')\
    +'</div><div id="shiftList">'+renderShiftList('all')+'</div></div>';\
\}\
function updateSlots()\{\
  var pgId=document.getElementById('shPG')?document.getElementById('shPG').value:'';\
  var grid=document.getElementById('slotGrid');\
  var manualRow=document.getElementById('manualTimeRow');\
  var sel=document.getElementById('slotSelected');\
  if(!grid) return;\
  document.getElementById('shDay').value=''; document.getElementById('shStart').value=''; document.getElementById('shEnd').value='';\
  sel.textContent='No slot selected'; sel.style.color='var(--sub)';\
  document.querySelectorAll('.shift-slot-btn').forEach(function(b)\{b.classList.remove('selected');\});\
  manualRow.classList.add('hidden');\
  if(!pgId)\{grid.innerHTML='<div style="grid-column:span 2;color:var(--sub);font-size:.85rem">Select a playgroup first</div>';return;\}\
  var slots=ALL_SLOTS[pgId]||[];\
  var isPersonal=pgId==='personal';\
  if(isPersonal) manualRow.classList.remove('hidden');\
  var pg=getPG(pgId);\
  grid.innerHTML=slots.map(function(s)\{\
    var color=pg?pg.color:'#2563eb';\
    return '<button type="button" class="shift-slot-btn" data-day="'+s.day+'" data-start="'+s.start+'" data-end="'+s.end+'" data-personal="'+(isPersonal?1:0)+'" onclick="pickSlot(this)">'\
      +'<div style="font-weight:800;color:'+color+';font-size:.88rem">'+s.day+'</div>'\
      +'<div style="font-size:.76rem;margin-top:3px;font-weight:600;color:'+(isPersonal?'var(--sub)':color)+'">'+( isPersonal?'Set manually':s.label)+'</div>'\
      +'</button>';\
  \}).join('');\
\}\
function pickSlot(btn)\{\
  document.querySelectorAll('.shift-slot-btn').forEach(function(b)\{b.classList.remove('selected');\});\
  btn.classList.add('selected');\
  var day=btn.getAttribute('data-day');\
  var isPersonal=btn.getAttribute('data-personal')==='1';\
  document.getElementById('shDay').value=day;\
  var sel=document.getElementById('slotSelected');\
  var pgId=document.getElementById('shPG').value;\
  var pg=getPG(pgId);\
  if(isPersonal)\{\
    document.getElementById('shStart').value=''; document.getElementById('shEnd').value='';\
    document.getElementById('manualStart').value=''; document.getElementById('manualEnd').value='';\
    sel.innerHTML='<strong>Personal Classes</strong> \'b7 <strong>'+day+'</strong> \'b7 Enter time below';\
    sel.style.color='#7c3aed';\
  \} else \{\
    document.getElementById('shStart').value=btn.getAttribute('data-start');\
    document.getElementById('shEnd').value=btn.getAttribute('data-end');\
    sel.innerHTML=(pg?pg.emoji+' <strong>'+pg.label+'</strong>':'')+' \'b7 <strong>'+day+'</strong> \'b7 <strong>'+btn.getAttribute('data-start')+' - '+btn.getAttribute('data-end')+'</strong>';\
    sel.style.color='#16a34a';\
  \}\
\}\
function applyManualTime()\{\
  var s=document.getElementById('manualStart').value; var e=document.getElementById('manualEnd').value;\
  document.getElementById('shStart').value=s; document.getElementById('shEnd').value=e;\
  var day=document.getElementById('shDay').value; var sel=document.getElementById('slotSelected');\
  if(s&&e&&day)\{ sel.innerHTML='<strong>Personal</strong> \'b7 <strong>'+day+'</strong> \'b7 <strong>'+s+' - '+e+'</strong>'; sel.style.color='#7c3aed'; \}\
\}\
function addShift()\{\
  var coach=document.getElementById('shCoach').value;\
  var pgId=document.getElementById('shPG').value;\
  var day=document.getElementById('shDay').value;\
  var date=document.getElementById('shDate').value;\
  var start=document.getElementById('shStart').value;\
  var end=document.getElementById('shEnd').value;\
  if(!coach)\{alert('Please select a coach.');return;\}\
  if(!day)\{alert('Please select a day/time slot.');return;\}\
  if(!start||!end)\{alert('Please enter start and end time.');return;\}\
  DB.shifts.push(\{id:uid(),coach:coach,playgroup:pgId,day:day,date:date,startTime:start,endTime:end\});\
  save();\
  document.getElementById('shiftList').innerHTML=renderShiftList('all');\
  document.querySelectorAll('.shift-slot-btn').forEach(function(b)\{b.classList.remove('selected');\});\
  document.getElementById('shDay').value=''; document.getElementById('shStart').value=''; document.getElementById('shEnd').value='';\
  document.getElementById('slotSelected').textContent='No slot selected'; document.getElementById('slotSelected').style.color='var(--sub)';\
  alert('Shift allocated: '+coachName(coach)+' \'b7 '+(getPG(pgId)?getPG(pgId).label:pgId)+' \'b7 '+day+' \'b7 '+start+'-'+end);\
\}\
function renderShiftList(filter)\{\
  var shifts=filter&&filter!=='all'?DB.shifts.filter(function(s)\{return s.playgroup===filter;\}):DB.shifts;\
  if(!shifts.length) return '<div style="color:var(--sub);font-size:.85rem">No shifts yet.</div>';\
  var ord=['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'];\
  shifts=shifts.slice().sort(function(a,b)\{return ord.indexOf(a.day)-ord.indexOf(b.day);\});\
  var html='<div class="table-wrap"><table><tr><th>Coach</th><th>Playgroup</th><th>Day</th><th>Time</th><th>Date</th><th></th></tr>';\
  shifts.forEach(function(s)\{\
    var pg=getPG(s.playgroup);\
    html+='<tr><td><strong>'+coachName(s.coach)+'</strong></td><td>'+(pg?pg.emoji+' '+pg.label:s.playgroup)+'</td>'\
      +'<td>'+s.day+'</td><td style="font-weight:600;color:#2563eb">'+s.startTime+'-'+s.endTime+'</td>'\
      +'<td>'+(s.date||'-')+'</td><td><button class="btn btn-danger btn-sm" onclick="deleteShift(\\''+s.id+'\\')">\uc0\u55357 \u56785 </button></td></tr>';\
  \});\
  html+='</table></div>';\
  return html;\
\}\
function filterShifts(f)\{ document.getElementById('shiftList').innerHTML=renderShiftList(f); \}\
function deleteShift(id)\{\
  if(!confirm('Remove this shift?')) return;\
  DB.shifts=DB.shifts.filter(function(s)\{return s.id!==id;\}); save();\
  document.getElementById('shiftList').innerHTML=renderShiftList('all');\
\}\
