      +'<div class="att-btns">'\
      +'<button class="att-btn present'+(a.status==='present'?' active':'')+'" onclick="markAtt(\\''+s.id+'\\',\\''+date+'\\',\\'present\\')" id="bp_'+s.id+'">\uc0\u10003  Present</button>'\
      +'<button class="att-btn absent'+(a.status==='absent'?' active':'')+'" onclick="markAtt(\\''+s.id+'\\',\\''+date+'\\',\\'absent\\')" id="ba_'+s.id+'">\uc0\u10007  Absent</button>'\
      +'</div></div>';\
  \}).join('');\
\}\
function markAtt(sid,date,status)\{\
  var ex=DB.attendance[attKey(date,sid)]||\{\};\
